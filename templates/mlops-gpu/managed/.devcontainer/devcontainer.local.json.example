{
  // This file is an example only. Dev Containers does not load
  // devcontainer.local.json.example automatically.
  //
  // Default workflow (committed devcontainer.json):
  //   export DATA_MOUNT_SOURCE=/path/on/docker-host
  //   Rebuild Container
  //
  // Use devcontainer.local.json when you prefer a gitignored hardcoded mount
  // instead of exporting before every Rebuild:
  //   1. Copy this file to devcontainer.local.json (already gitignored).
  //   2. Uncomment ONE option below.
  //   3. Rebuild Container.
  //
  // Docker bind mounts use paths on the machine that runs Docker.
  // Do not put NFS server export strings here, such as:
  //   192.168.3.14:/mnt/storage/data

  // Option A (recommended default): keep using host env var DATA_MOUNT_SOURCE.
  // No devcontainer.local.json needed — see data-mount.env.example and README.md.

  // Option B: hardcoded host path (gitignored via devcontainer.local.json).
  //
  // "initializeCommand": "ls /path/on/docker-host >/dev/null && test -d /path/on/docker-host",
  // "mounts": [
  //   "source=/path/on/docker-host,target=/data,type=bind"
  // ]

  // Option C: autofs NFS on main_gpu (host path /mnt/data).
  //
  // "initializeCommand": "ls /mnt/data >/dev/null",
  // "mounts": [
  //   "source=/mnt/data,target=/data,type=bind"
  // ]

  // Option D: local empty fallback for GPU smoke only (no real datasets).
  //
  // "initializeCommand": "mkdir -p \"${localEnv:HOME}/.local/share/mlops-empty-data\"",
  // "mounts": [
  //   "source=${localEnv:HOME}/.local/share/mlops-empty-data,target=/data,type=bind"
  // ]

  // Option E: sibling input/ next to the repo (monorepo layout only).
  //
  // "mounts": [
  //   "source=${localWorkspaceFolder}/../input,target=/data,type=bind"
  // ]
}
