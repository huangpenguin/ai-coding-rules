{
  "name": "AI MLOps GPU Template",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "initializeCommand": "test -n \"${localEnv:DATA_MOUNT_SOURCE}\" && ls \"${localEnv:DATA_MOUNT_SOURCE}\" >/dev/null && test -d \"${localEnv:DATA_MOUNT_SOURCE}\" || (echo 'ERROR: export DATA_MOUNT_SOURCE before Rebuild.' >&2 && echo 'Example: export DATA_MOUNT_SOURCE=/path/to/your/input' >&2 && exit 1)",
  "mounts": [
    "source=${localEnv:DATA_MOUNT_SOURCE},target=/data,type=bind"
  ],
  "runArgs": [
    "--gpus",
    "all",
    "--shm-size",
    "16g"
  ],
  "containerEnv": {
    "PYTHONUNBUFFERED": "1",
    "UV_LINK_MODE": "copy",
    "DATA_DIR": "/data"
  },
  "postCreateCommand": "bash scripts/uv-bootstrap.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.terminal.activateEnvironment": false
      }
    }
  }
}
