# Shell profile snippet — NOT auto-loaded by Dev Containers.
#
# Copy the export line to ~/.zshrc or ~/.bashrc, or run before Rebuild Container.
# Dev Containers reads ${localEnv:DATA_MOUNT_SOURCE} from the host process environment.

export DATA_MOUNT_SOURCE=/path/to/your/input

# Optional: per-dataset override inside the container (absolute path under /data)
# export BATTERY_TIFF_DIR=/data/my_dataset/subdir
