# Copy to deploy-hf-space.env in the project root (add deploy-hf-space.env to .gitignore).
# Used by scripts/deploy-hf-space.sh for local deploys. CI should use GitHub secrets/vars instead.

HF_SPACE_GIT_URL="https://huggingface.co/spaces/you/your-space"
HF_TOKEN="hf_..."
# HF_USERNAME="your-hf-username"

# Repo-relative paths removed from the export before push (whitespace-separated).
DEPLOY_EXCLUDE_PATHS="sample_docs/public/legacy"
